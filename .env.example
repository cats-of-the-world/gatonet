# ── Identity ──────────────────────────────────────────────────────────────────
# Run: id $(whoami)  to get your PUID and PGID
PUID=1000
PGID=1000
TZ=Europe/Oslo

# ── Paths ─────────────────────────────────────────────────────────────────────
# Where container config/state is stored
CONFIG_PATH=/opt/gatonet/config
# Where torrents are downloaded (temporary staging)
DOWNLOADS_PATH=/opt/gatonet/downloads
# Final organized library (Radarr and Sonarr move files here)
MEDIA_PATH=/opt/gatonet/media

# ── Network ───────────────────────────────────────────────────────────────────
# Your server's LAN IP (e.g. 192.168.1.100).
# All web UIs will ONLY be reachable at this address — not from the internet.
# Run: hostname -I | awk '{print $1}'
LAN_IP=192.168.1.100

# ── Commercial VPN (for torrent traffic) ──────────────────────────────────────
# Gluetun docs: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
#
# ── Mullvad (recommended) ──
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=<your Mullvad WireGuard private key>
# WIREGUARD_ADDRESSES=10.x.x.x/32   (shown in Mullvad account > WireGuard keys)
# VPN_SERVER_COUNTRIES=Netherlands
#
# ── NordVPN ──
# VPN_SERVICE_PROVIDER=nordvpn
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=<generated via NordVPN API>
# VPN_SERVER_COUNTRIES=Netherlands
#
# ── ProtonVPN ──
# VPN_SERVICE_PROVIDER=protonvpn
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=<from ProtonVPN account > Downloads > WireGuard>
# WIREGUARD_ADDRESSES=10.x.x.x/32
# VPN_SERVER_COUNTRIES=Netherlands

VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=REPLACE_ME
WIREGUARD_ADDRESSES=REPLACE_ME
VPN_SERVER_COUNTRIES=Netherlands
