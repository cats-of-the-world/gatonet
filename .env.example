# Identity
# Run: id $(whoami)  to get your PUID and PGID
PUID=1000
PGID=1000
TZ=Europe/Oslo

# Paths
# Where container config/state is stored
CONFIG_PATH=/opt/gatonet/config

# Single data root shared by all containers.
# Downloads and media must share one filesystem so Radarr/Sonarr can hardlink
# files instead of copying them (avoids doubling disk usage).
#
# Layout created by setup.sh:
#   DATA_PATH/
#   |-- downloads/
#   |   |-- complete/movies/
#   |   |-- complete/tv/
#   |   `-- incomplete/
#   `-- media/
#       |-- movies/
#       `-- tv/
DATA_PATH=/opt/gatonet/data

# VPN (for torrent traffic)
# Gluetun docs: https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
#
# Mullvad (recommended)
# VPN_SERVICE_PROVIDER=mullvad
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=<your Mullvad WireGuard private key>
# WIREGUARD_ADDRESSES=10.x.x.x/32   (shown in Mullvad account > WireGuard keys)
# VPN_SERVER_COUNTRIES=Netherlands
#
# NordVPN
# VPN_SERVICE_PROVIDER=nordvpn
# VPN_TYPE=openvpn
# OPENVPN_USER=<account dashboard > Manual setup > Service credentials > username>
# OPENVPN_PASSWORD=<account dashboard > Manual setup > Service credentials > password>
# VPN_SERVER_COUNTRIES=Netherlands
#
# ProtonVPN
# VPN_SERVICE_PROVIDER=protonvpn
# VPN_TYPE=wireguard
# WIREGUARD_PRIVATE_KEY=<from ProtonVPN account > Downloads > WireGuard>
# WIREGUARD_ADDRESSES=10.x.x.x/32
# VPN_SERVER_COUNTRIES=Netherlands

VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=REPLACE_ME
WIREGUARD_ADDRESSES=REPLACE_ME
VPN_SERVER_COUNTRIES=Netherlands
